# ─── DATABASE ───────────────────────────────────────────────────────────────
# DigitalOcean Managed Postgres connection string
DATABASE_URL=postgresql://user:password@host:25060/vinstub?sslmode=require

# ─── REDIS ──────────────────────────────────────────────────────────────────
# DigitalOcean Managed Redis (TLS required in production)
REDIS_URL=rediss://default:password@host:25061

# ─── AUTH ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_32_byte_hex_string
REFRESH_SECRET=replace_with_different_32_byte_hex_string

# JWT expiry (seconds)
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# ─── STRIPE ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PREMIUM=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ─── RESEND (EMAIL) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=noreply@vinstub.com
RESEND_FROM_NAME=VINSTUB.com

# ─── SENTRY ─────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@o....ingest.sentry.io/...

# ─── APP ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
# Base URL used for Stripe redirect URLs (no trailing slash)
APP_BASE_URL=http://localhost:3000

# ─── ADMIN ──────────────────────────────────────────────────────────────────
# Static shared secret — first factor for /admin/* routes
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=replace_with_strong_random_secret

# Base32-encoded TOTP seed — second factor for /admin/* routes
# Generate with: node -e "const {authenticator}=require('otplib'); console.log(authenticator.generateSecret())"
# Then scan the otpauth:// URI into your authenticator app
ADMIN_TOTP_SECRET=JBSWY3DPEHPK3PXP

# ─── RATE LIMITING OVERRIDES (optional — defaults in constants.ts) ───────────
# Leave unset to use defaults from shared/constants.ts
# RATE_LIMIT_FREE_DAILY=50
# RATE_LIMIT_BASIC_DAILY=500
# RATE_LIMIT_PREMIUM_DAILY=5000
# RATE_LIMIT_ENTERPRISE_DAILY=50000

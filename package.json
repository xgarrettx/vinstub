{
  "name": "vinstub",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "start": "node apps/api/dist/server.js"
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter api db:migrate",
    "db:studio": "pnpm --filter api db:studio",
    "ingest:validate": "pnpm --filter api ingest:validate",
    "ingest:clean": "pnpm --filter api ingest:clean",
    "ingest:promote": "pnpm --filter api ingest:promote"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsx": "^4.21.0",
    "turbo": "^2.8.21",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.4.0"
    }
  },
  "dependencies": {
    "otplib": "^13.4.0",
    "redis-server": "^1.2.2"
  }
}

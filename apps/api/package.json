{
  "name": "@vinstub/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "node --require tsx/cjs node_modules/drizzle-kit/bin.cjs generate --config drizzle.config.ts",
    "db:migrate": "node --require tsx/cjs node_modules/drizzle-kit/bin.cjs migrate --config drizzle.config.ts",
    "db:push": "node --require tsx/cjs node_modules/drizzle-kit/bin.cjs push --config drizzle.config.ts",
    "db:studio": "node --require tsx/cjs node_modules/drizzle-kit/bin.cjs studio --config drizzle.config.ts",
    "ingest": "tsx --env-file=.env src/scripts/ingest/import.ts"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/sensible": "^5.6.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "@sentry/node": "^8.55.1",
    "@vinstub/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "csv-parse": "^5.6.0",
    "drizzle-orm": "^0.36.4",
    "fastify": "^4.29.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "otplib": "^12.0.1",
    "pg": "^8.20.0",
    "resend": "^3.5.0",
    "stripe": "^16.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.28.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
